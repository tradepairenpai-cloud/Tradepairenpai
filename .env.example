# Set DEMO_MODE=true to allow mock render URLs without failing QA (default: true).
# For real video rendering, set DEMO_MODE=false and provide a real CREATOMATE_API_KEY.
DEMO_MODE=true
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CREATOMATE_API_KEY=your_creatomate_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here
APP_PORT=3000
NODE_ENV=development
OUTPUT_DIR=./outputs
ASSET_DIR=./assets
LOG_LEVEL=info
