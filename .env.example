# ─── AI CLI Tools ─────────────────────────────────────────────────────────────
# Claude CLI is pre-installed in this environment (claude --version to verify).
# Codex CLI: npm install -g @openai/codex
# Gemini CLI: npm install -g @google/gemini-cli

# ─── AI / LLM APIs ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Content Production APIs ──────────────────────────────────────────────────
CREATOMATE_API_KEY=your_creatomate_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Publishing APIs ──────────────────────────────────────────────────────────
# TikTok — use Client Key / Secret from TikTok Developer Portal
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_REDIRECT_URL=http://localhost:3000/api/auth/tiktok/callback
# Obtained after TikTok OAuth flow
TIKTOK_USER_ACCESS_TOKEN=
# Legacy single-key (optional; only needed if using non-OAuth TikTok API)
TIKTOK_API_KEY=your_tiktok_api_key_here
YOUTUBE_API_KEY=your_youtube_data_api_key_here
# Meta Page Access Token (from Facebook Developer Portal)
META_API_KEY=your_meta_page_access_token_here
# Instagram Business Account ID (from Facebook Business Manager)
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# ─── App Config ───────────────────────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=development
OUTPUT_DIR=./outputs
ASSET_DIR=./assets
LOG_LEVEL=info

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# DEMO_MODE=true  → mock render URLs are acceptable (QA shows warning, not fail)
# DEMO_MODE=false → production mode; QA fails if any output is mock
DEMO_MODE=true

# ─── YouTube Publisher Config ──────────────────────────────────────────────────
# YOUTUBE_VISIBILITY=private → อัปโหลดเป็น Private เสมอ (ค่าเริ่มต้น)
# เปลี่ยนเป็น public ได้เฉพาะเมื่อตั้งค่า YOUTUBE_VISIBILITY=public ชัดเจนเท่านั้น
YOUTUBE_AUTO_PUBLISH=true
YOUTUBE_REQUIRE_OWNER_APPROVAL=false
YOUTUBE_PUBLISH_MODE=AUTO_PUBLISH
YOUTUBE_VISIBILITY=private
YOUTUBE_CHANNEL_ID=UC1T5c2VEolzUDEEgA1fzQlg
YOUTUBE_CATEGORY=Education
YOUTUBE_MADE_FOR_KIDS=false

# ─── YouTube OAuth 2.0 ─────────────────────────────────────────────────────────
# ต้องใช้ OAuth 2.0 สำหรับการอัปโหลดวิดีโอ — API Key อย่างเดียวใช้ได้แค่ read-only
#
# YOUTUBE_CLIENT_ID    : ได้จาก Google Cloud Console → APIs & Services → Credentials
#                        สร้าง OAuth 2.0 Client ID (Web application)
# YOUTUBE_CLIENT_SECRET: ดูจาก Google Cloud Console (ห้าม commit ค่าจริงใน repo สาธารณะ)
# YOUTUBE_REDIRECT_URI : ต้องตรงกับ Authorized redirect URIs ใน Google Cloud Console
#                        สำหรับ GitHub Codespace: https://{CODESPACE_NAME}-3000.app.github.dev/api/auth/youtube/callback
#                        สำหรับ Local: http://localhost:3000/api/auth/youtube/callback
#                        ระบบ auto-detect ได้เองถ้าไม่ได้ตั้งค่า
# YOUTUBE_OAUTH_TOKEN  : ได้หลัง login ผ่าน /api/auth/youtube/login (บันทึกอัตโนมัติ)
# YOUTUBE_REFRESH_TOKEN: ใช้ต่ออายุ access token อัตโนมัติเมื่อหมดอายุ
#
# ขั้นตอน:
#   1. ไปที่ https://console.cloud.google.com/apis/credentials
#   2. สร้าง OAuth 2.0 Client ID (Web application)
#   3. รัน: npm run youtube:auth → จะแสดง Redirect URI ที่ถูกต้องสำหรับ environment นี้
#   4. เพิ่ม URI นั้นใน Authorized redirect URIs ใน Google Cloud Console
#   5. ใส่ CLIENT_SECRET ใน .env → รัน npm run youtube:auth อีกครั้ง → เปิด URL → login
YOUTUBE_CLIENT_ID=746395926197-ndra0p9k44kfmik9nrhis5c4ef317u6e.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret_from_google_cloud
# ถ้าไม่ตั้งค่า YOUTUBE_REDIRECT_URI ระบบจะ auto-detect จาก CODESPACE_NAME หรือ localhost
YOUTUBE_REDIRECT_URI=https://your-codespace-name-3000.app.github.dev/api/auth/youtube/callback
# ค่าด้านล่างจะถูกบันทึกอัตโนมัติหลัง OAuth login — ไม่ต้องใส่เอง
YOUTUBE_OAUTH_TOKEN=
YOUTUBE_REFRESH_TOKEN=

# ─── Platform Access Control ───────────────────────────────────────────────────
# อนุญาตเฉพาะ YouTube เท่านั้น — แพลตฟอร์มอื่นทั้งหมดถูกล็อก
NON_YOUTUBE_PUBLISHER_LOCKED=true
REQUIRE_OWNER_APPROVAL_FOR_NON_YOUTUBE=true
APPROVE_NON_YOUTUBE_PUBLISH=false
PUBLISH_ALLOWED_PLATFORMS=youtube
PUBLISH_BLOCKED_PLATFORMS=tiktok,facebook,instagram,meta,buffer,metricool,later,zapier,make,n8n
